# ====================================================================
# CANTON DEVNET ENVIRONMENT VARIABLES
# ====================================================================

# TradingApp pattern: tokens flow only between users (no operator custody).
# When true: self-allocation at order placement, both parties sign at match.
# When false: operator-as-receiver (current flow).
USE_TRADING_APP_PATTERN=true

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ====================================================================
# CANTON ENDPOINTS
# ====================================================================

# JSON Ledger API (HTTP/WS) - PRIMARY API for all reads/writes
CANTON_JSON_LEDGER_API_BASE=http://65.108.40.104:31539

# Admin API (gRPC) - for DAR uploads and admin operations
CANTON_ADMIN_API_GRPC_HOST=65.108.40.104
CANTON_ADMIN_API_GRPC_PORT=30100

# Ledger API (gRPC) - for ledger operations
CANTON_LEDGER_API_GRPC_HOST=65.108.40.104
CANTON_LEDGER_API_GRPC_PORT=31217

# ====================================================================
# CANTON IDENTITY
# ====================================================================

# Default synchronizer ID (REQUIRED for all commands)
DEFAULT_SYNCHRONIZER_ID=global-domain::...

# Operator party ID (REQUIRED for all operations - wallet allocation, order placement)
OPERATOR_PARTY_ID=...
FAUCET_PARTY_ID=...

# Package name for template IDs (package-name format)
PACKAGE_NAME=clob-exchange

# ====================================================================
# OAUTH CONFIGURATION
# ====================================================================

# Keycloak token endpoint 
KEYCLOAK_TOKEN_URL=https://keycloak.wolfedgelabs.com:8443/realms/canton-devnet/protocol/openid-connect/token

# Validator Operator credentials
OAUTH_CLIENT_ID=...
OAUTH_CLIENT_SECRET=...
OAUTH_SCOPE=openid profile email daml_ledger_api

# ====================================================================
# KEYCLOAK & SCAN API
# ====================================================================

SCAN_PROXY_BASE=https://wallet.validator.dev.canton.wolfedgelabs.com/api/validator/v0/scan-proxy
SCAN_API_PREFIX=/api/scan
KEYCLOAK_BASE_URL=https://keycloak.wolfedgelabs.com:8443
KEYCLOAK_REALM=canton-devnet

# ====================================================================
# MATCHING ENGINE
# ====================================================================

MATCHING_ENGINE_ENABLED=true
MATCHING_ENGINE_INTERVAL_MS=1000
ALLOCATION_SETTLE_WINDOW_MS=900000

# ====================================================================
# PACKAGE CONFIGURATION
# ====================================================================

CLOB_EXCHANGE_PACKAGE_ID=8e02305ce3c4154710ee0227ac547fc8a03e526d66fed2621bf31bdd1e1b247b
TOKEN_STANDARD_PACKAGE_ID=...

NODE_TLS_REJECT_UNAUTHORIZED=0

# ====================================================================
# DATABASE & EXECUTOR
# ====================================================================

DATABASE_URL=postgresql://cardiv-user:xxxx@cardiv-pg.dev.canton.wolfedgelabs.com:6543/cardiv?sslmode=require

EXECUTOR_PARTY_ID=...
EXECUTOR_CLIENT_ID=cardiv
EXECUTOR_CLIENT_SECRET=...
